:{$PORT} {
    root * dist
    file_server
    try_files {path} /index.html
    
    header {
        # Enable HTTP Strict Transport Security (HSTS)
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        # Prevent browsers from incorrectly detecting the type of content
        X-Content-Type-Options "nosniff"
        # Protect against clickjacking
        X-Frame-Options "DENY"
        # Basic Content Security Policy
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co https://api.openai.com https://api.anthropic.com;"
    }
}
