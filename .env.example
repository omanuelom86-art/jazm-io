# Evolution API v2 - Configuración Corregida
# Documentación: https://evolution-api.com/v2/config/env

# General
SERVER_URL=https://info86-nexus-server.hf.space
EVOLUTION_API_KEY=Supera

# Base de Datos (Corregido para v2)
# Si usas PostgreSQL o MySQL, cambia el provider y la URI
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgres://user:pass@host:5432/db
DATABASE_CONNECTION_CLIENT_NAME=evolution

# Si prefieres MongoDB (verifica si tu versión lo soporta, v2 prefiere SQL)
# DATABASE_ENABLED=true
# DATABASE_PROVIDER=mongodb
# DATABASE_CONNECTION_URI=mongodb://localhost:27017/evolution

# Almacenamiento
STORE_MESSAGES=true
STORE_MESSAGE_UP=true
STORE_CONTACTS=true
STORE_CHATS=true

# Instancias
INSTANCE_PATH=/app/instances

# Webhooks
WEBHOOK_GLOBAL_ENABLED=false
WEBHOOK_GLOBAL_URL=
WEBHOOK_GLOBAL_VALUE=
